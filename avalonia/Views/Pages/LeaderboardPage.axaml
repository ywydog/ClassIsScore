<UserControl x:Class="ClassIsScore.Views.Pages.LeaderboardPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClassIsScore.ViewModels"
             xmlns:models="clr-namespace:ClassIsScore.Models"
             xmlns:converters="clr-namespace:ClassIsScore.Converters"
             x:DataType="vm:LeaderboardViewModel"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="600">

    <UserControl.Resources>
        <converters:RankToMedalBrushConverter x:Key="RankToMedalBrushConverter" />
        <converters:RankToMedalVisibilityConverter x:Key="RankToMedalVisibilityConverter" />
        <converters:RankToNormalVisibilityConverter x:Key="RankToNormalVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- 工具栏按钮样式 -->
        <Style Selector="Button.ToolbarButton">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- 排行榜交替行颜色 -->
        <Style Selector="ListBoxItem:nth-child(odd)">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:nth-child(even)">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- 顶部工具栏：时间范围 + 日期选择 -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- 时间范围选择 -->
                <TextBlock Text="时间范围："
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,0,4,0" />
                <ComboBox x:Name="TimeRangeComboBox"
                          SelectedIndex="0"
                          MinWidth="100"
                          VerticalAlignment="Center"
                          SelectionChanged="OnTimeRangeSelectionChanged">
                    <ComboBoxItem Content="日排行" />
                    <ComboBoxItem Content="周排行" />
                    <ComboBoxItem Content="月排行" />
                    <ComboBoxItem Content="全部排行" />
                </ComboBox>

                <!-- 分隔线 -->
                <Border Width="1"
                        Height="24"
                        Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                        VerticalAlignment="Center"
                        Margin="8,0" />

                <!-- 日期选择器 -->
                <CalendarDatePicker x:Name="DatePicker"
                                    SelectedDate="{Binding SelectedDate}"
                                    MinWidth="140"
                                    VerticalAlignment="Center"
                                    IsTodayHighlighted="True" />

                <!-- 刷新按钮 -->
                <Button Classes="ToolbarButton"
                        Command="{Binding RefreshCommand}"
                        Content="刷新"
                        Margin="8,0,0,0" />

                <!-- 导出按钮 -->
                <Button Classes="ToolbarButton"
                        Click="OnExportClick"
                        Content="导出" />
            </StackPanel>
        </Border>

        <!-- Tab 切换：个人排行榜 / 小组排行榜 -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,6">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="PersonalTabButton"
                        Content="个人排行榜"
                        Click="OnPersonalTabClick"
                        Padding="20,8"
                        FontSize="14" />
                <Button x:Name="GroupTabButton"
                        Content="小组排行榜"
                        Click="OnGroupTabClick"
                        Padding="20,8"
                        FontSize="14"
                        IsVisible="{Binding HasGroups}" />
            </StackPanel>
        </Border>

        <!-- 排行榜列表 -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding LeaderboardEntries}"
                 Margin="8,4">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:LeaderboardEntry">
                    <Grid ColumnDefinitions="50,*,Auto"
                          Margin="4,8">

                        <!-- 排名区域 -->
                        <Panel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- 奖牌圆圈（前三名） -->
                            <Border Width="32" Height="32" CornerRadius="16"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsVisible="{Binding Rank, Converter={StaticResource RankToMedalVisibilityConverter}}"
                                    Background="{Binding Rank, Converter={StaticResource RankToMedalBrushConverter}}">
                                <TextBlock Text="{Binding Rank}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Bold" Foreground="White" />
                            </Border>
                            <!-- 普通排名文字（第4名及以后） -->
                            <TextBlock Text="{Binding Rank}"
                                       IsVisible="{Binding Rank, Converter={StaticResource RankToNormalVisibilityConverter}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Panel>

                        <!-- 姓名/小组名 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Margin="12,0,0,0" />

                        <!-- 积分 -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="4"
                                Padding="12,4"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Score, StringFormat='{}{0:0.##}'}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>
