<UserControl x:Class="ClassIsScore.Views.Pages.SettingsPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClassIsScore.ViewModels"
             x:DataType="vm:SettingsViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="700">

    <UserControl.Styles>
        <!-- 设置卡片样式：标题+描述+右侧控件 -->
        <Style Selector="Border.setting-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="Border.setting-card:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>

        <!-- 设置分组标题 -->
        <Style Selector="TextBlock.setting-group-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>

        <!-- 设置项标题 -->
        <Style Selector="TextBlock.setting-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- 设置项描述 -->
        <Style Selector="TextBlock.setting-desc">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- 入场动画：从下方淡入滑入 -->
        <Style Selector="Border.animate-in">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut" />
                    <DoubleTransition Property="TranslateTransform.Y" Duration="0:0:0.3" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Tab项样式 -->
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- 页面标题区 -->
        <Border Grid.Row="0" Padding="24,20,24,0">
            <StackPanel Spacing="4">
                <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="管理应用外观、功能和行为偏好"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Tab内容区 -->
        <TabControl x:Name="SettingsTabControl"
                    Grid.Row="1"
                    Padding="24,8,24,24"
                    SelectedIndex="0">

            <!-- ==================== 外观标签页 ==================== -->
            <TabItem Header="外观">
                <ScrollViewer>
                    <StackPanel Spacing="2" MaxWidth="700">

                        <!-- 主题分组 -->
                        <TextBlock Text="主题" Classes="setting-group-title" />

                        <!-- 深色模式 -->
                        <Border Classes="setting-card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="深色模式" Classes="setting-title" />
                                    <TextBlock Text="在深色和浅色主题之间切换" Classes="setting-desc" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding IsDarkMode}"
                                              OnContent="深色"
                                              OffContent="浅色"
                                              IsCheckedChanged="OnDarkModeToggled" />
                            </Grid>
                        </Border>

                        <!-- 主题色 -->
                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="主题色" Classes="setting-title" />
                                    <TextBlock Text="选择应用的主题色" Classes="setting-desc" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding PresetAccentColors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemWidth="44" ItemHeight="44" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Button Padding="0"
                                                    Margin="4"
                                                    CornerRadius="20"
                                                    Width="36"
                                                    Height="36"
                                                    Click="OnAccentColorClicked"
                                                    Tag="{Binding}">
                                                <Button.Content>
                                                    <Border CornerRadius="18" Width="36" Height="36">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding}" />
                                                        </Border.Background>
                                                    </Border>
                                                </Button.Content>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 字体分组 -->
                        <TextBlock Text="字体" Classes="setting-group-title" />

                        <!-- 自定义字体 -->
                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="自定义字体" Classes="setting-title" />
                                    <TextBlock Text="选择应用显示字体，默认使用 HarmonyOS Sans SC" Classes="setting-desc" />
                                </StackPanel>
                                <ComboBox x:Name="FontComboBox"
                                          ItemsSource="{Binding FontFamilies}"
                                          SelectedItem="{Binding SelectedFontFamily}"
                                          HorizontalAlignment="Stretch"
                                          MaxDropDownHeight="300">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontFamily="{Binding}"
                                                       Text="{Binding Name, FallbackValue=HarmonyOS Sans SC（默认）}"
                                                       VerticalAlignment="Center"
                                                       MaxWidth="500"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- 字体预览 -->
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="6"
                                        Padding="12"
                                        Margin="0,4,0,0">
                                    <TextBox Text="{Binding FontPreviewText}"
                                             IsReadOnly="True"
                                             FontFamily="{Binding SelectedFontFamily}"
                                             FontSize="14"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             TextAlignment="Center"
                                             Margin="0"
                                             Padding="0"
                                             BorderThickness="0"
                                             Background="Transparent" />
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== 功能标签页 ==================== -->
            <TabItem Header="功能">
                <ScrollViewer>
                    <StackPanel Spacing="2" MaxWidth="700">

                        <!-- 悬浮窗分组 -->
                        <TextBlock Text="悬浮窗" Classes="setting-group-title" />

                        <!-- 启用悬浮窗 -->
                        <Border Classes="setting-card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="启用悬浮窗" Classes="setting-title" />
                                    <TextBlock Text="在桌面上显示悬浮窗，快速查看积分信息" Classes="setting-desc" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding IsFloatingWindowEnabled}"
                                              OnContent="启用"
                                              OffContent="禁用" />
                            </Grid>
                        </Border>

                        <!-- 悬浮窗详细设置（仅启用时可见） -->
                        <StackPanel Spacing="2" IsVisible="{Binding IsFloatingWindowEnabled}">

                            <!-- 样式选择 -->
                            <Border Classes="setting-card">
                                <StackPanel Spacing="8">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="悬浮窗样式" Classes="setting-title" />
                                        <TextBlock Text="经典模式：圆形按钮+图标+文字标签；纯图标模式：圆形裁切图片" Classes="setting-desc" />
                                    </StackPanel>
                                    <ComboBox SelectedIndex="{Binding FloatingWindowStyle}"
                                              HorizontalAlignment="Left"
                                              MinWidth="180">
                                        <ComboBoxItem Content="经典模式" />
                                        <ComboBoxItem Content="纯图标模式" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- 透明度 -->
                            <Border Classes="setting-card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="透明度" Classes="setting-title" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Slider Grid.Column="0"
                                                Minimum="0.1"
                                                Maximum="1.0"
                                                Value="{Binding FloatingWindowOpacity}"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FloatingWindowOpacity, StringFormat={}{0:P0}}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Width="48"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 大小 -->
                            <Border Classes="setting-card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="按钮大小" Classes="setting-title" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Slider Grid.Column="0"
                                                Minimum="40"
                                                Maximum="80"
                                                Value="{Binding FloatingWindowSize}"
                                                TickFrequency="4"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FloatingWindowSize, StringFormat={}{0:0}}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Width="48"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 经典模式专属设置 -->
                            <StackPanel Spacing="2" IsVisible="{Binding IsClassicStyle}">

                                <TextBlock Text="经典模式设置" Classes="setting-group-title" />

                                <!-- 显示文本 -->
                                <Border Classes="setting-card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="显示文本" Classes="setting-title" />
                                        <TextBox Text="{Binding FloatingWindowDisplayText}"
                                                 MaxLength="4"
                                                 Width="120"
                                                 HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>

                                <!-- 显示标签开关 -->
                                <Border Classes="setting-card">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="显示文本标签" Classes="setting-title" />
                                            <TextBlock Text="在图标下方显示文本标识" Classes="setting-desc" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsChecked="{Binding FloatingWindowShowLabel}"
                                                      OnContent="显示"
                                                      OffContent="隐藏" />
                                    </Grid>
                                </Border>

                                <!-- 悬浮窗主题色 -->
                                <Border Classes="setting-card">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="悬浮窗主题色" Classes="setting-title" />
                                            <TextBlock Text="选择悬浮窗按钮的颜色" Classes="setting-desc" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding FloatingPresetAccentColors}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" ItemWidth="44" ItemHeight="44" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Button Padding="0"
                                                            Margin="4"
                                                            CornerRadius="20"
                                                            Width="36"
                                                            Height="36"
                                                            Click="OnFloatingAccentColorClicked"
                                                            Tag="{Binding}">
                                                        <Button.Content>
                                                            <Border CornerRadius="18" Width="36" Height="36">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding}" />
                                                                </Border.Background>
                                                            </Border>
                                                        </Button.Content>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- 系统托盘分组 -->
                        <TextBlock Text="系统托盘" Classes="setting-group-title" />

                        <Border Classes="setting-card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="显示托盘图标" Classes="setting-title" />
                                    <TextBlock Text="在系统托盘区显示应用图标，方便快速访问" Classes="setting-desc" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding ShowTrayIcon}"
                                              OnContent="显示"
                                              OffContent="隐藏" />
                            </Grid>
                        </Border>

                        <Border Classes="setting-card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="关闭时最小化到托盘" Classes="setting-title" />
                                    <TextBlock Text="关闭窗口时最小化到系统托盘而不是退出应用" Classes="setting-desc" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding CloseToTray}"
                                              OnContent="启用"
                                              OffContent="禁用" />
                            </Grid>
                        </Border>

                        <!-- 高级功能分组 -->
                        <TextBlock Text="高级功能" Classes="setting-group-title" />

                        <Border Classes="setting-card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="管理员设置" Classes="setting-title" />
                                    <TextBlock Text="配置管理员验证方式和权限" Classes="setting-desc" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="toolbar"
                                        Content="前往设置"
                                        Command="{Binding NavigateToAdminSettingsCommand}" />
                            </Grid>
                        </Border>

                        <Border Classes="setting-card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="自动评价设置" Classes="setting-title" />
                                    <TextBlock Text="配置自动评价规则和触发条件" Classes="setting-desc" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="toolbar"
                                        Content="前往设置"
                                        Command="{Binding NavigateToAutoEvaluationCommand}" />
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== 插件标签页 ==================== -->
            <TabItem Header="插件">
                <ScrollViewer>
                    <StackPanel Spacing="2" MaxWidth="700">

                        <!-- 插件管理分组 -->
                        <TextBlock Text="已安装插件" Classes="setting-group-title" />

                        <!-- 插件列表 -->
                        <Border Classes="setting-card" IsVisible="{Binding HasPlugins}">
                            <ItemsControl ItemsSource="{Binding Plugins}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,8" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <!-- 插件图标 -->
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE735;" FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                               FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                                <!-- 插件信息 -->
                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Manifest.Name}" Classes="setting-title" />
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}v{0} · {1}">
                                                                <Binding Path="Manifest.Version" />
                                                                <Binding Path="Manifest.Author" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Manifest.Description}" Classes="setting-desc" />
                                                </StackPanel>
                                                <!-- 启用开关 -->
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding IsEnabled}"
                                                              OnContent="启用"
                                                              OffContent="禁用"
                                                              VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- 无插件提示 -->
                        <Border Classes="setting-card" IsVisible="{Binding !HasPlugins}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,24">
                                <TextBlock Text="&#xE894;" FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="32" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="暂无已安装的插件" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="将插件文件夹放入 data/Plugins/ 目录即可自动加载" HorizontalAlignment="Center"
                                           FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- 插件目录 -->
                        <TextBlock Text="插件目录" Classes="setting-group-title" />

                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="插件存储位置" Classes="setting-title" />
                                    <TextBlock Text="插件从此目录自动加载，每个子文件夹需包含 manifest.json" Classes="setting-desc" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Text="{Binding PluginFolderPath}" IsReadOnly="True" />
                                    <Button Grid.Column="1" Classes="toolbar" Content="打开"
                                            Command="{Binding OpenPluginFolderCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== 自定义主题标签页 ==================== -->
            <TabItem Header="自定义主题">
                <ScrollViewer>
                    <StackPanel Spacing="2" MaxWidth="700">

                        <!-- 自定义主题分组 -->
                        <TextBlock Text="已安装主题" Classes="setting-group-title" />

                        <!-- 主题列表 -->
                        <Border Classes="setting-card" IsVisible="{Binding HasCustomThemes}">
                            <ItemsControl ItemsSource="{Binding CustomThemes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,8" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <!-- 主题图标 -->
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE771;" FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                               FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                                <!-- 主题信息 -->
                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Manifest.Name}" Classes="setting-title" />
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}v{0} · {1}">
                                                                <Binding Path="Manifest.Version" />
                                                                <Binding Path="Manifest.Author" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Manifest.Description}" Classes="setting-desc" />
                                                </StackPanel>
                                                <!-- 操作按钮 -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <ToggleSwitch IsChecked="{Binding IsEnabled}"
                                                                  OnContent="启用"
                                                                  OffContent="禁用" />
                                                    <Button Content="删除" FontSize="12" Padding="8,4"
                                                            Tag="{Binding Manifest.Id}"
                                                            Click="OnDeleteThemeClicked" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- 无主题提示 -->
                        <Border Classes="setting-card" IsVisible="{Binding !HasCustomThemes}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,24">
                                <TextBlock Text="&#xE790;" FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="32" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="暂无自定义主题" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="导入 .cisui 主题包或手动放入 data/Themes/ 目录" HorizontalAlignment="Center"
                                           FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- 导入主题 -->
                        <TextBlock Text="导入主题" Classes="setting-group-title" />

                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="导入 .cisui 主题包" Classes="setting-title" />
                                    <TextBlock Text="选择一个 .cisui 格式的主题包文件进行安装" Classes="setting-desc" />
                                </StackPanel>
                                <Button Content="选择文件并导入" Command="{Binding ImportThemeCommand}"
                                        HorizontalAlignment="Left" Padding="16,6" />
                            </StackPanel>
                        </Border>

                        <!-- 主题目录 -->
                        <TextBlock Text="主题目录" Classes="setting-group-title" />

                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="主题存储位置" Classes="setting-title" />
                                    <TextBlock Text="自定义主题从此目录加载，每个子文件夹需包含 manifest.json 和 Theme.axaml" Classes="setting-desc" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Text="{Binding ThemesFolderPath}" IsReadOnly="True" />
                                    <Button Grid.Column="1" Classes="toolbar" Content="打开"
                                            Command="{Binding OpenThemesFolderCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== 关于标签页 ==================== -->
            <TabItem Header="关于">
                <ScrollViewer>
                    <StackPanel Spacing="2" MaxWidth="700">

                        <!-- 应用信息分组 -->
                        <TextBlock Text="应用信息" Classes="setting-group-title" />

                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <!-- 应用图标 -->
                                    <Border Width="64" Height="64"
                                            CornerRadius="12"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                                        <Image Source="avares://ClassIsScore/Assets/AppLogo.png"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock FontSize="18" FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}ClassIsScore v{0}">
                                                    <Binding Path="AppVersion" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="班级积分管理系统"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 技术栈 -->
                        <Border Classes="setting-card">
                            <StackPanel Spacing="4">
                                <TextBlock Text="技术栈" Classes="setting-title" />
                                <TextBlock Text="Avalonia UI · FluentAvalonia · .NET 8"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="CommunityToolkit.Mvvm · Microsoft.Extensions.Hosting"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- 数据管理分组 -->
                        <TextBlock Text="数据管理" Classes="setting-group-title" />

                        <!-- 数据目录 -->
                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="数据目录" Classes="setting-title" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding DataFolderPath}"
                                             IsReadOnly="True" />
                                    <Button Grid.Column="1"
                                            Classes="toolbar"
                                            Content="打开"
                                            Command="{Binding OpenDataFolderCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 数据导出/导入 -->
                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="数据导出与导入" Classes="setting-title" />
                                    <TextBlock Text="导出所有应用数据为zip备份文件，或从zip文件恢复数据" Classes="setting-desc" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Content="导出所有数据"
                                            Command="{Binding ExportDataCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="12,6" />
                                    <Button Grid.Column="1"
                                            Content="导入数据"
                                            Command="{Binding ImportDataCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="12,6" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 学生数据导出/导入 -->
                        <Border Classes="setting-card">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="学生数据导出与导入" Classes="setting-title" />
                                    <TextBlock Text="仅导出或导入学生数据（支持Excel/CSV/zip格式）" Classes="setting-desc" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Content="导出学生数据"
                                            Command="{Binding ExportStudentsCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="12,6" />
                                    <Button Grid.Column="1"
                                            Content="导入学生数据"
                                            Command="{Binding ImportStudentsCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="12,6" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 传输进度 -->
                        <Border Classes="setting-card" IsVisible="{Binding IsTransferring}">
                            <StackPanel Spacing="8">
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding TransferProgress}" />
                                <TextBlock Text="{Binding TransferStatus}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
