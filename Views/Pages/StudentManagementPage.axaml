<UserControl x:Class="ClassIsScore.Views.Pages.StudentManagementPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClassIsScore.ViewModels"
             xmlns:models="clr-namespace:ClassIsScore.Models"
             x:DataType="vm:StudentManagementViewModel"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="600">

    <UserControl.Styles>
        <!-- 工具栏按钮样式 -->
        <Style Selector="Button.ToolbarButton">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.ToolbarButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.ToolbarButton:pressed">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- 添加学生按钮 -->
                <Button Classes="ToolbarButton"
                        Command="{Binding AddStudentCommand}"
                        Content="添加学生" />

                <!-- 导入Excel按钮 -->
                <Button Classes="ToolbarButton"
                        Click="OnImportExcelClick"
                        Content="导入 Excel" />

                <!-- 导入CSV按钮 -->
                <Button Classes="ToolbarButton"
                        Click="OnImportCsvClick"
                        Content="导入 CSV" />

                <!-- 分隔 -->
                <Border Width="1"
                        Height="24"
                        Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                        VerticalAlignment="Center"
                        Margin="8,0" />

                <!-- 排序选项 -->
                <TextBlock Text="排序："
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <ComboBox SelectedIndex="{Binding SortOptionIndex}"
                          MinWidth="120"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="按姓名" />
                    <ComboBoxItem Content="按学号" />
                </ComboBox>

                <!-- 刷新按钮 -->
                <Button Classes="ToolbarButton"
                        Command="{Binding LoadStudentsCommand}"
                        Content="刷新"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 学生列表 -->
        <Panel Grid.Row="1">
            <ListBox ItemsSource="{Binding Students}"
                     SelectedItem="{Binding SelectedStudent}"
                     DoubleTapped="OnStudentDoubleTapped"
                     Margin="8,4">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Student">
                        <Grid ColumnDefinitions="40,*,120,60,80"
                              Margin="4,6">
                            <!-- 头像占位 -->
                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="16"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </Border>

                            <!-- 姓名 -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />

                            <!-- 学号 -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding StudentNumber}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis" />

                            <!-- 性别 -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Gender}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13" />

                            <!-- 当前积分 -->
                            <TextBlock Grid.Column="4"
                                       Text="{Binding Score}"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <!-- 空状态提示 -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding Students.Count, Converter={x:Static models:CountToVisibilityConverter.InvertedInstance}}">
                <TextBlock Text="暂无学生数据"
                           FontSize="16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="点击上方「添加学生」按钮开始"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Panel>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock x:Name="StatusText" Text="共 0 名学生" />
        </Border>

        <!-- 编辑对话框遮罩 -->
        <Panel Grid.RowSpan="3"
               IsVisible="{Binding IsEditDialogOpen}">
            <Border Background="{DynamicResource SystemControlPageBackgroundMediumAltBrush}"
                    Opacity="0">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                    </Transitions>
                </Border.Transitions>
            </Border>
            <Border x:Name="EditDialogBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    MinWidth="360"
                    RenderTransformOrigin="0.5,0.5"
                    Opacity="0"
                    RenderTransform="scale(0.95)">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                        <DoubleTransition Property="ScaleTransform.ScaleX" Duration="0:0:0.25" Easing="CubicEaseOut" />
                        <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.25" Easing="CubicEaseOut" />
                    </Transitions>
                </Border.Transitions>
                <StackPanel>
                    <TextBlock Text="{Binding EditDialogTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />

                    <!-- 姓名 -->
                    <TextBlock Text="姓名 *" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditingStudent.Name}"
                             Watermark="请输入姓名"
                             Margin="0,0,0,12" />

                    <!-- 学号 -->
                    <TextBlock Text="学号" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditingStudent.StudentNumber}"
                             Watermark="请输入学号"
                             Margin="0,0,0,12" />

                    <!-- 性别 -->
                    <TextBlock Text="性别" Margin="0,0,0,4" />
                    <ComboBox SelectedItem="{Binding EditingStudent.Gender}"
                              MinWidth="200"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="男" />
                        <ComboBoxItem Content="女" />
                    </ComboBox>

                    <!-- 宠物类型 -->
                    <TextBlock Text="宠物类型" Margin="0,0,0,4" />
                    <ComboBox x:Name="PetTypeComboBox"
                              MinWidth="200"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,12"
                              SelectedIndex="0"
                              SelectionChanged="OnPetTypeSelectionChanged">
                        <ComboBoxItem Content="未领养" Tag="" />
                    </ComboBox>

                    <!-- 按钮区域 -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8"
                                Margin="0,8,0,0">
                        <Button Content="取消"
                                Click="OnEditDialogCancel" />
                        <Button Content="保存"
                                Command="{Binding SaveStudentCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Panel>
    </Grid>
</UserControl>
