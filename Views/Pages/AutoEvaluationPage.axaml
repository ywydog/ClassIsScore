<UserControl x:Class="ClassIsScore.Views.Pages.AutoEvaluationPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClassIsScore.ViewModels"
             xmlns:models="clr-namespace:ClassIsScore.Models"
             x:DataType="vm:AutoEvaluationViewModel"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="600">

    <UserControl.Styles>
        <Style Selector="Button.ActionButton">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="自动评价管理"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="添加配置"
                        Command="{Binding AddConfigCommand}"
                        Padding="16,6" />
            </Grid>
        </Border>

        <!-- 配置列表 -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Configs}"
                  SelectedItem="{Binding SelectedConfig}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  Margin="8,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120" />
                <DataGridTemplateColumn Header="触发类型" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:AutoEvaluationConfig">
                            <TextBlock Text="{Binding TriggerType}"
                                       VerticalAlignment="Center"
                                       Margin="4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="触发时间" Binding="{Binding TriggerTime, StringFormat='{}{0:hh\\:mm}'}" Width="80" />
                <DataGridTemplateColumn Header="目标" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:AutoEvaluationConfig">
                            <TextBlock Text="{Binding TargetType}"
                                       VerticalAlignment="Center"
                                       Margin="4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="积分变动" Binding="{Binding ScoreChange}" Width="80" />
                <DataGridTextColumn Header="原因" Binding="{Binding Reason}" Width="*" />
                <DataGridTemplateColumn Header="状态" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:AutoEvaluationConfig">
                            <Border CornerRadius="4"
                                    Padding="8,2"
                                    HorizontalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding IsEnabled, Converter={x:Static models:BoolToColorConverter.Instance}}" />
                                </Border.Background>
                                <TextBlock Text="{Binding IsEnabled, Converter={x:Static models:BoolToTextConverter.Instance}}"
                                           Foreground="White"
                                           FontSize="11"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:AutoEvaluationConfig">
                            <StackPanel Orientation="Horizontal">
                                <Button Classes="ActionButton"
                                        Content="编辑"
                                        Command="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).EditConfigCommand}"
                                        CommandParameter="{Binding}" />
                                <Button Classes="ActionButton"
                                        Content="切换启用"
                                        Command="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).ToggleEnabledCommand}"
                                        CommandParameter="{Binding}" />
                                <Button Classes="ActionButton"
                                        Content="删除"
                                        Command="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).DeleteConfigCommand}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>

        <!-- 编辑对话框遮罩 -->
        <Border Grid.RowSpan="3"
                IsVisible="{Binding IsEditDialogOpen}"
                Background="#80000000">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="24"
                    Width="480"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12" DataContext="{Binding EditingConfig}" x:DataType="models:AutoEvaluationConfig">
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Text="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).DialogTitle}" />

                    <!-- 配置名称 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="名称：" VerticalAlignment="Center" FontSize="13" />
                        <TextBox Grid.Column="1" Text="{Binding Name}" Watermark="请输入配置名称" />
                    </Grid>

                    <!-- 触发类型 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="触发类型：" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).TriggerTypes}"
                                  SelectedItem="{Binding TriggerType}"
                                  HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 触发时间 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="触发时间：" VerticalAlignment="Center" FontSize="13" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding TriggerTime, StringFormat='{}{0:hh\\:mm}'}"
                                 Watermark="如 08:00" />
                    </Grid>

                    <!-- 周几触发（仅Weekly） -->
                    <Grid ColumnDefinitions="80,*"
                          IsVisible="{Binding TriggerType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:TriggerType.Weekly}}">
                        <TextBlock Text="星期：" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).WeekDays}"
                                  SelectedItem="{Binding DayOfWeek}"
                                  HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 每月几号（仅Monthly） -->
                    <Grid ColumnDefinitions="80,*"
                          IsVisible="{Binding TriggerType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:TriggerType.Monthly}}">
                        <TextBlock Text="日期：" VerticalAlignment="Center" FontSize="13" />
                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding DayOfMonth}"
                                       Minimum="1"
                                       Maximum="31"
                                       HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 目标类型 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="目标类型：" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).TargetTypes}"
                                  SelectedItem="{Binding TargetType}"
                                  HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 指定小组（仅SpecificGroup） -->
                    <Grid ColumnDefinitions="80,*"
                          IsVisible="{Binding TargetType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:TargetType.SpecificGroup}}">
                        <TextBlock Text="小组：" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).Groups}"
                                  SelectedItem="{Binding TargetGroupId}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 指定学生（仅SpecificStudent） -->
                    <Grid ColumnDefinitions="80,*"
                          IsVisible="{Binding TargetType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:TargetType.SpecificStudent}}">
                        <TextBlock Text="学生：" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).Students}"
                                  SelectedItem="{Binding TargetStudentId}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 关联评价项 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="评价项：" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).EvaluationItems}"
                                  SelectedItem="{Binding EvaluationItemId}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- 积分变动 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="积分变动：" VerticalAlignment="Center" FontSize="13" />
                        <TextBox Grid.Column="1" Text="{Binding ScoreChange}" Watermark="正为加，负为减" />
                    </Grid>

                    <!-- 原因 -->
                    <Grid ColumnDefinitions="80,*">
                        <TextBlock Text="原因：" VerticalAlignment="Center" FontSize="13" />
                        <TextBox Grid.Column="1" Text="{Binding Reason}" Watermark="请输入原因" />
                    </Grid>

                    <!-- 是否启用 -->
                    <CheckBox Content="启用此配置" IsChecked="{Binding IsEnabled}" />

                    <!-- 操作按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                        <Button Content="取消"
                                Command="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).CancelEditCommand}"
                                Padding="16,6" />
                        <Button Content="保存"
                                Command="{Binding $parent[UserControl].((vm:AutoEvaluationViewModel)DataContext).SaveConfigCommand}"
                                Padding="16,6" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
