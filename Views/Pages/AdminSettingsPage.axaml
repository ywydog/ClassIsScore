<UserControl x:Class="ClassIsScore.Views.Pages.AdminSettingsPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClassIsScore.ViewModels"
             xmlns:models="clr-namespace:ClassIsScore.Models"
             xmlns:services="clr-namespace:ClassIsScore.Services.Abstractions"
             x:DataType="vm:AdminSettingsViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600">

    <ScrollViewer>
        <StackPanel Margin="32,24" Spacing="20" MaxWidth="700">

            <!-- 页面标题 -->
            <TextBlock Text="管理员验证设置"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="配置管理员身份验证方式，保护系统设置不被未授权修改"
                       FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16" />

            <!-- 启用管理员验证开关 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="启用管理员验证" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="开启后，修改系统设置需要先通过管理员验证"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding IsAdminEnabled}"
                                  OnContent="已启用"
                                  OffContent="已禁用" />
                </Grid>
            </Border>

            <!-- 验证方式选择 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="验证方式" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="选择管理员验证的主要方式"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <ComboBox ItemsSource="{Binding VerificationMethods}"
                              SelectedItem="{Binding SelectedVerificationMethod}"
                              HorizontalAlignment="Stretch"
                              MinWidth="250" />
                </StackPanel>
            </Border>

            <!-- 密码验证设置 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="密码验证" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="HasPassword" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding IsPasswordEnabled}"
                                      OnContent="启用"
                                      OffContent="禁用" />
                    </Grid>

                    <StackPanel Spacing="8" IsVisible="{Binding IsPasswordEnabled}">
                        <TextBlock Text="设置密码" FontSize="14" />
                        <TextBox PasswordChar="*"
                                 Text="{Binding NewPassword}"
                                 Watermark="请输入密码"
                                 MinWidth="300" />

                        <TextBlock Text="确认密码" FontSize="14" Margin="0,8,0,0" />
                        <TextBox PasswordChar="*"
                                 Text="{Binding ConfirmPassword}"
                                 Watermark="请再次输入密码"
                                 MinWidth="300" />

                        <Button Content="设置密码"
                                Command="{Binding SetPasswordCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- U盘验证设置 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="U盘验证" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="插入指定U盘作为管理员身份验证凭证"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding IsUsbEnabled}"
                                      OnContent="启用"
                                      OffContent="禁用" />
                    </Grid>

                    <StackPanel Spacing="8" IsVisible="{Binding IsUsbEnabled}">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding UsbDevices}"
                                      SelectedItem="{Binding SelectedUsbDevice}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="250">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="services:UsbDeviceInfo">
                                        <TextBlock Text="{Binding VolumeLabel}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="1"
                                    Content="刷新"
                                    Command="{Binding RefreshUsbDevicesCommand}" />
                            <Button Grid.Column="2"
                                    Content="选择此设备"
                                    Command="{Binding SelectUsbDeviceCommand}" />
                        </Grid>

                        <Button Content="测试U盘验证"
                                Command="{Binding TestUsbVerifyCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 人脸验证设置（预留） -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="人脸验证" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="通过人脸识别进行管理员身份验证"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding IsFaceEnabled}"
                                      OnContent="启用"
                                      OffContent="禁用"
                                      IsEnabled="False" />
                    </Grid>

                    <Border Background="{DynamicResource ControlFillColorDisabledBrush}"
                            CornerRadius="6"
                            Padding="16,12">
                        <StackPanel Spacing="4" Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="人脸验证功能即将支持，敬请期待"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <Button Content="保存设置"
                    Command="{Binding SaveEnabledCommand}"
                    HorizontalAlignment="Left"
                    Padding="24,8" />

            <!-- 状态消息 -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
