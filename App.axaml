<Application x:Class="ClassIsScore.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styling="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <styling:FluentAvaloniaTheme CustomAccentColor="#4CC2FF" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- ==================== 字体系统 (Font Hierarchy) ==================== -->
            <!-- 默认字体：HarmonyOS Sans SC (华为开源中文字体，参考ClassIsland) -->
            <FontFamily x:Key="HarmonyOsSans">
                /ClassIsScore;component/Assets/Fonts/#HarmonyOS Sans SC,
                HarmonyOS Sans SC,
                Noto Sans CJK SC,
                Microsoft YaHei UI,
                SimHei,
                sans-serif
            </FontFamily>

            <FontFamily x:Key="ContentControlThemeFontFamily">{StaticResource HarmonyOsSans}</FontFamily>

            <!-- 字体大小层级 -->
            <x:Double x:Key="FontSizeCaption">11</x:Double>
            <x:Double x:Key="FontSizeBody">13</x:Double>
            <x:Double x:Key="FontSizeBodyLarge">14</x:Double>
            <x:Double x:Key="FontSizeSubTitle">16</x:Double>
            <x:Double x:Key="FontSizeTitle">20</x:Double>
            <x:Double x:Key="FontSizeDisplay">28</x:Double>

            <!-- ==================== 间距系统 (Spacing System) ==================== -->
            <x:Double x:Key="SpacingXs">2</x:Double>
            <x:Double x:Key="SpacingSm">4</x:Double>
            <x:Double x:Key="SpacingMd">8</x:Double>
            <x:Double x:Key="SpacingLg">12</x:Double>
            <x:Double x:Key="SpacingXl">16</x:Double>
            <x:Double x:Key="SpacingXxl">20</x:Double>
            <x:Double x:Key="SpacingXxxl">24</x:Double>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <!-- ==================== 全局字体样式 (HarmonyOS Sans SC) ==================== -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource HarmonyOsSans}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        </Style>

        <!-- ==================== 按钮交互增强 ==================== -->
        <Style Selector="Button:pointerover">
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- ==================== 列表项交互反馈 ==================== -->
        <!-- 注意: /template 选择器需在控件模板上下文中使用，此处仅保留基础样式 -->

        <!-- ==================== 卡片/面板基础样式 (参考ClassIsland) ==================== -->
        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="{StaticResource SpacingXl}" />
        </Style>

        <Style Selector="Border.dialog">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="{StaticResource SpacingXxl}" />
        </Style>

        <!-- ==================== 工具栏按钮样式 ==================== -->
        <Style Selector="Button.toolbar">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.toolbar:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.toolbar:pressed">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
        </Style>

        <!-- ==================== 文本层级样式 ==================== -->
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>

        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSubTitle}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.display">
            <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ==================== 分割线样式 ==================== -->
        <Style Selector="Border.divider">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Margin" Value="8,0" />
        </Style>

        <Style Selector="Border.divider-vertical">
            <Setter Property="Width" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
    </Application.Styles>
</Application>
