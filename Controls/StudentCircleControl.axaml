<UserControl x:Class="ClassIsScore.Controls.StudentCircleControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClassIsScore.ViewModels"
             x:DataType="vm:StudentDisplayItem"
             mc:Ignorable="d"
             Width="130"
             Height="160"
             Margin="6">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="4"
                PointerPressed="OnCirclePointerPressed">

        <!-- 圆形头像区域 -->
        <Grid Width="100"
              Height="100">
            <!-- 圆形头像背景 -->
            <Border Width="100"
                    Height="100"
                    CornerRadius="50"
                    ClipToBounds="True"
                    Background="{DynamicResource AccentFillColorDefaultBrush}">
                <Panel>
                    <Image x:Name="AvatarImage"
                           Source="{Binding Avatar}"
                           Stretch="UniformToFill"
                           IsVisible="False" />
                    <TextBlock x:Name="InitialText"
                               Text="{Binding Initial}"
                               FontSize="36"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Panel>
            </Border>

            <!-- 积分叠加层：底部四分之一位置，半透明背景 -->
            <Border VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    CornerRadius="10"
                    Padding="8,2"
                    Margin="0,0,0,4">
                <Border.Background>
                    <SolidColorBrush Color="#CC000000" />
                </Border.Background>
                <TextBlock Text="{Binding ScoreText}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>

        <!-- 姓名显示 -->
        <TextBlock Text="{Binding Name}"
                   FontSize="13"
                   FontWeight="Medium"
                   HorizontalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="120" />
    </StackPanel>
</UserControl>
