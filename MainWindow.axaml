<Window x:Class="ClassIsScore.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        mc:Ignorable="d"
        Title="ClassIsScore - 班级积分管理系统"
        Width="1100"
        Height="700"
        MinWidth="800"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica"
        Background="Transparent"
        TransparencyBackgroundFallback="{DynamicResource SolidBackgroundFillColorBaseBrush}">

    <!-- 窗口背景过渡动画（参考ClassIsland） -->
    <Window.Transitions>
        <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.25" />
        </Transitions>
    </Window.Transitions>

    <fa:NavigationView x:Name="NavView"
                       IsPaneToggleButtonVisible="True"
                       PaneDisplayMode="Left"
                       IsPaneOpen="True"
                       OpenPaneLength="220"
                       Loaded="NavView_Loaded">

        <!-- 自定义标题栏区域（参考ClassIsland无系统装饰窗口设计） -->
        <fa:NavigationView.PaneHeader>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,8,0,0">
                <Image Width="20" Height="20"
                       Source="/Assets/AppLogo.png"
                       VerticalAlignment="Center" />
                <TextBlock Text="ClassIsScore"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </fa:NavigationView.PaneHeader>

        <!-- 导航菜单项 -->
        <fa:NavigationView.MenuItems>
            <fa:NavigationViewItem Content="主页" Tag="Home" IconSource="Home" />
            <fa:NavigationViewItem Content="积分显示" Tag="ScoreDisplay" IconSource="View" />
            <fa:NavigationViewItem Content="学生管理" Tag="StudentManagement" IconSource="People" />
            <fa:NavigationViewItem Content="积分管理" Tag="ScoreManagement" IconSource="Star" />
            <fa:NavigationViewItem Content="结算" Tag="Settlement" IconSource="Calculate" />
            <fa:NavigationViewItem Content="排行榜" Tag="Leaderboard" IconSource="Trophy" />
            <fa:NavigationViewItem Content="历史记录" Tag="History" IconSource="History" />
        </fa:NavigationView.MenuItems>

        <!-- 底部导航项 -->
        <fa:NavigationView.FooterMenuItems>
            <fa:NavigationViewItem Content="设置" Tag="Settings" IconSource="Settings" />
        </fa:NavigationView.FooterMenuItems>

        <!-- 页面内容区域 -->
        <ScrollViewer>
            <Panel x:Name="ContentPanel">
                <!-- 页面将在此处动态加载 -->
            </Panel>
        </ScrollViewer>
    </fa:NavigationView>
</Window>
